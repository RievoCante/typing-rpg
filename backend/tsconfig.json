{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "node"],
    "paths": {
      "cloudflare:workers": ["./__mocks__/cloudflare-workers.ts"]
    }
  }
}
